N1N_API_KEY=replace_with_your_api_key
N1N_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat
VISION_MODEL_NAME=deepseek-chat
ENABLE_MULTIMODAL_VISION=true
ENABLE_MM_COMPAT_MODE=true
ENABLE_MM_SCREEN_COMMENT=true
MM_TIMEOUT_SEC=5.0
MM_FAILURE_THRESHOLD=3
MM_COOLDOWN_SEC=120
MM_IMAGE_MAX_EDGE=1280
ENABLE_AUTO_COMMENT_HEARTBEAT=true
ENABLE_TUTOR_PERSONA=false
ENABLE_TTS=true
TTS_PROVIDER=edge
# edge / azure / voicevox
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
# Azure Speech (when TTS_PROVIDER=azure)
TTS_AZURE_KEY=
TTS_AZURE_REGION=
# Optional. If set, can be used instead of region.
TTS_AZURE_ENDPOINT=
# VOICEVOX (when TTS_PROVIDER=voicevox)
TTS_VOICEVOX_BASE_URL=http://127.0.0.1:50021
# This is VOICEVOX style/speaker id, e.g. 1, 3, 8 ...
TTS_VOICEVOX_SPEAKER=1
# Auto start local VOICEVOX engine when port is unreachable.
ENABLE_VOICEVOX_AUTO_LAUNCH=true
# Path to VOICEVOX engine executable (run.exe)
TTS_VOICEVOX_ENGINE_PATH=G:\py\桌宠\Script\desktop_pet\VOICEVOX\VOICEVOX\vv-engine\run.exe
# Translate Chinese output to Japanese before sending to VOICEVOX.
ENABLE_VOICEVOX_JA_TRANSLATION=true
# WebEngine render mode for Live2D: gpu / software / auto
WEBENGINE_GPU_MODE=gpu
# Run auto scan pipeline in a dedicated process to reduce UI contention.
ENABLE_SCAN_SUBPROCESS=true
SCAN_MONITOR_INDEX=1
# Live2D display
ENABLE_LIVE2D=true
LIVE2D_MODEL_JSON=G:\py\桌宠\皮套\mao_pro_zh\runtime\mao_pro.model3.json
ENABLE_LIVE2D_PY=false
# Backward-compatible alias. If true, ENABLE_LIVE2D_PY is implied.
ENABLE_LIVE2D_PY_POC=false
LIVE2D_PY_WINDOW_WIDTH=280
LIVE2D_PY_WINDOW_HEIGHT=430
LIVE2D_FOLLOW_CURSOR=true
# Enable gaze follow only when cursor is near pet window (in pixels).
LIVE2D_FOLLOW_ACTIVATE_DISTANCE_PX=220
LIVE2D_MODEL_SCALE=1.0
LIVE2D_IDLE_GROUP=Idle
# Optional region on selected monitor: left,top,width,height
SCAN_REGION=
# Optional high-frequency scan tick for memory accumulation. 0 means auto-calc.
SCAN_TICK_INTERVAL_SEC=0
# Minimum interval between scan task submissions in seconds. 0 means auto-calc.
SCAN_SUBMIT_MIN_INTERVAL_SEC=0
# Scan busy timeout in seconds. Exceeded tasks trigger worker reset.
SCAN_BUSY_TIMEOUT_SEC=12
# Process resource policy tuning (Windows):
# Enter active_hard mode when a scan has run this many seconds.
RESOURCE_POLICY_HARD_AFTER_SEC=2.5
# Keep a short recovery window after each scan so UI/audio can catch up.
RESOURCE_POLICY_RELEASE_GRACE_SEC=1.2
# Minimum seconds between repeated resource policy applications.
RESOURCE_POLICY_REAPPLY_MIN_SEC=4.0
# Optional memory weighting recency window in seconds. 0 means auto-calc.
MEMORY_RECENCY_WINDOW_SEC=0
# Minimum weight floor for older memory items in [0.0, 1.0].
MEMORY_MIN_WEIGHT=0.15
# Long-memory items used by screen comments (0 disables long-memory hint).
SCREEN_COMMENT_MEMORY_LIMIT=3
# Suggested long-memory influence weight in screen-comment prompt [0.0, 1.0].
SCREEN_COMMENT_MEMORY_WEIGHT=0.2
# Skip auto comment when similarity with previous auto comment is too high.
COMMENT_SIMILARITY_SKIP_THRESHOLD=0.86
SCREEN_SCAN_INTERVAL_SEC=45
AUTO_COMMENT_COOLDOWN_SEC=60
