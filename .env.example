# ============================================
# Desktop Pet Environment Configuration
# ============================================
# Use this file as a template. Copy to .env and edit values.
# Boolean values accepted: true/false, 1/0, yes/no, on/off.

# ============================================
# [A] LLM / API
# ============================================
# Main API key. Also supports DEEPSEEK_API_KEY as fallback alias in code.
N1N_API_KEY=replace_with_your_api_key
# OpenAI-compatible endpoint base URL.
N1N_BASE_URL=https://api.deepseek.com/v1
# Text model for chat and comment generation.
MODEL_NAME=deepseek-chat
# Vision model for screenshot understanding. If empty, uses MODEL_NAME.
VISION_MODEL_NAME=deepseek-chat

# ============================================
# [B] Multimodal Scan Pipeline
# ============================================
# Master switch: whether to attempt vision model on screenshots.
ENABLE_MULTIMODAL_VISION=true
# Compatibility mode with timeout/failure cooldown fallback to OCR.
ENABLE_MM_COMPAT_MODE=true
# Whether auto comments use multimodal vision path.
ENABLE_MM_SCREEN_COMMENT=true
# Vision request timeout in seconds. Range: 1.0 ~ 30.0.
MM_TIMEOUT_SEC=5.0
# Consecutive multimodal failures before entering cooldown. Range: 1 ~ 12.
MM_FAILURE_THRESHOLD=3
# Cooldown seconds after repeated multimodal failures. Range: 10 ~ 3600.
MM_COOLDOWN_SEC=120
# Max image edge for vision input resize. Range: 320 ~ 2048.
MM_IMAGE_MAX_EDGE=1280

# ============================================
# [C] Runtime Behavior
# ============================================
# Print auto-comment heartbeat logs.
ENABLE_AUTO_COMMENT_HEARTBEAT=true
# Show/hide role=系统 messages in chat window. false improves immersion; true is useful for debugging.
CHAT_SHOW_SYSTEM_MESSAGES=false
# Show session-segment marker on chat roles (e.g. 桌宠(自动)[S2]) for archive-cycle debugging.
CHAT_SHOW_SESSION_DEBUG_MARKER=false
# Enable tutor persona mode at startup.
ENABLE_TUTOR_PERSONA=false

# ============================================
# [D] TTS
# ============================================
# Master switch for speech playback.
ENABLE_TTS=true
# TTS provider: edge / azure / voicevox
TTS_PROVIDER=edge
# Voice name used by edge/azure provider.
TTS_VOICE=zh-CN-XiaoxiaoNeural
# Speech rate, e.g. +0%, -10%, +20%.
TTS_RATE=+0%
# Speech volume, e.g. +0%, -10%, +20%.
TTS_VOLUME=+0%

# Azure Speech (used when TTS_PROVIDER=azure)
TTS_AZURE_KEY=
TTS_AZURE_REGION=
# Optional endpoint. If set, can be used instead of region.
TTS_AZURE_ENDPOINT=

# VOICEVOX (used when TTS_PROVIDER=voicevox)
TTS_VOICEVOX_BASE_URL=http://127.0.0.1:50021
# VOICEVOX style/speaker id, e.g. 1, 3, 8.
TTS_VOICEVOX_SPEAKER=1
# Auto-start local VOICEVOX engine when base URL is unreachable.
ENABLE_VOICEVOX_AUTO_LAUNCH=true
# Path to VOICEVOX engine executable (run.exe). Supports absolute or project-relative path.
TTS_VOICEVOX_ENGINE_PATH=VOICEVOX/VOICEVOX/vv-engine/run.exe
# Translate Chinese output to Japanese before VOICEVOX synthesis.
ENABLE_VOICEVOX_JA_TRANSLATION=true

# ============================================
# [E] Live2D / Render
# ============================================
# WebEngine render mode: gpu / software / auto
WEBENGINE_GPU_MODE=gpu
# Global Live2D master switch.
ENABLE_LIVE2D=true
# Path to .model3.json (absolute or project-relative).
LIVE2D_MODEL_JSON=皮套/mao_pro_zh/runtime/mao_pro.model3.json
# Use external live2d-py renderer process mode.
ENABLE_LIVE2D_PY=false
# Backward-compatible alias. If true, ENABLE_LIVE2D_PY is implied.
ENABLE_LIVE2D_PY_POC=false
# Initial live2d-py model area size (not host panel size).
LIVE2D_PY_WINDOW_WIDTH=280
LIVE2D_PY_WINDOW_HEIGHT=430
# Cursor follow enable switch.
LIVE2D_FOLLOW_CURSOR=true
# Cursor distance threshold (px) to activate follow gate. Range: 40 ~ 2000.
LIVE2D_FOLLOW_ACTIVATE_DISTANCE_PX=220
# Runner input diagnostic log switch. 0=off (recommended), 1=on for debugging.
# When enabled, runner prints periodic [DIAG][RUNNER] snapshots.
LIVE2D_INPUT_DIAG=0
# Filter noisy runtime line "can't start motion" from live2d native logs.
# 1 keeps terminal clean when motion still plays normally; set 0 to see raw logs.
LIVE2D_FILTER_MOTION_NOISE_LOG=1
# Live2D model scale. Range: 0.2 ~ 3.0.
LIVE2D_MODEL_SCALE=1.0
# Preferred idle motion group name.
LIVE2D_IDLE_GROUP=Idle

# ============================================
# [F] Scan Target and Scheduler
# ============================================
# Run scan pipeline in dedicated subprocess for smoother UI.
ENABLE_SCAN_SUBPROCESS=true
# Target monitor index (1-based). Use 1 unless multiple displays are needed.
SCAN_MONITOR_INDEX=1
# Optional region on selected monitor: left,top,width,height
# Empty means full selected monitor.
SCAN_REGION=
# Tick interval for scan scheduler in seconds.
# 0 means auto-calc from SCREEN_SCAN_INTERVAL_SEC.
SCAN_TICK_INTERVAL_SEC=0
# Minimum interval between scan task submissions in seconds.
# 0 means auto-calc.
SCAN_SUBMIT_MIN_INTERVAL_SEC=0
# Busy timeout for a scan task before worker reset. Min: 5.
SCAN_BUSY_TIMEOUT_SEC=12
# OCR worker thread cap. 0 = runtime default.
# Suggested: 2~4 for lower CPU spikes.
OCR_CPU_THREADS=0
# Try DirectML backend for OCR (Windows GPU path). true/false
OCR_USE_DML=false
# Try CUDA backend for OCR if environment supports it. true/false
OCR_USE_CUDA=false
# OCR worker CPU affinity core count. 0 = no extra cap.
# Suggested: 2~4 on multicore machines.
OCR_CPU_AFFINITY_COUNT=0
# Max edge for OCR input image resize. 0 = keep original size.
# Suggested: 960~1280 to reduce OCR load.
OCR_MAX_EDGE=0

# ============================================
# [G] Windows Resource Policy Tuning
# ============================================
# Enter hard OCR policy when scan active longer than this many seconds.
# Range: 0.5 ~ 30.0
RESOURCE_POLICY_HARD_AFTER_SEC=2.5
# Grace period after scan for UI/audio recovery. Range: 0.0 ~ 10.0
RESOURCE_POLICY_RELEASE_GRACE_SEC=1.2
# Minimum interval between policy reapply operations. Range: 0.2 ~ 20.0
RESOURCE_POLICY_REAPPLY_MIN_SEC=4.0

# ============================================
# [H] Memory and Comment Policy
# ============================================
# Recency window (seconds) for cycle memory weighting.
# 0 means auto-calc.
MEMORY_RECENCY_WINDOW_SEC=0
# Minimum retained weight for old memory. Range: 0.0 ~ 1.0.
MEMORY_MIN_WEIGHT=0.15
# Number of long-memory entries injected into auto-comment prompt.
# 0 disables long-memory hint.
SCREEN_COMMENT_MEMORY_LIMIT=3
# Suggested long-memory influence in prompt. Range: 0.0 ~ 1.0.
SCREEN_COMMENT_MEMORY_WEIGHT=0.2
# Skip emitting comment if similarity with previous comment exceeds threshold.
# Range: 0.0 ~ 1.0.
COMMENT_SIMILARITY_SKIP_THRESHOLD=0.86
# Base interval (seconds) for auto-comment scheduling.
SCREEN_SCAN_INTERVAL_SEC=45
# Cooldown (seconds) between emitted auto comments.
AUTO_COMMENT_COOLDOWN_SEC=60

# ============================================
# [I] Auto Comment Style and Emotion Context
# ============================================
# Base style weights (before emotion multipliers).
# Format: style:weight pairs, comma-separated.
# Supported style keys:
#   陪伴评论, 轻松提问, 俏皮打趣, 温柔锐评, 行动建议
# Weight range per style (effective clamp in code): 0.0 ~ 5.0.
AUTO_COMMENT_STYLE_WEIGHTS=陪伴评论:1.0,轻松提问:1.2,俏皮打趣:1.0,温柔锐评:0.8,行动建议:1.0
# Comma-separated keyword dictionaries for emotion inference.
EMOTION_KEYWORDS_STRESSED=烦,崩溃,压力,焦虑,累,卡住,不会,好难,deadline,bug,报错,错误,失败,加班,熬夜,头疼,麻了
EMOTION_KEYWORDS_POSITIVE=哈哈,开心,搞定,完成,顺利,不错,太好了,舒服,进步,通过,成功,耶,轻松,满意
EMOTION_KEYWORDS_FOCUSED=学习,复习,写作业,刷题,阅读,写代码,调试,文档,论文,做题,专注,计划,总结,记笔记
